# ============================================================
# TE CUIDA — Variables de entorno
# ============================================================
# Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local a git (está en .gitignore).
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# URL de tu proyecto Supabase (Project URL en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave anónima (anon/public) — segura para el navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (service_role) — NUNCA se expone al navegador
# Solo se usa en Server Components, API Routes y Middleware admin
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Dominio base ────────────────────────────────────────────
# Dominio raíz de la plataforma para construir subdominios
# Producción: tecuida.es
# Desarrollo: localhost:3000
NEXT_PUBLIC_BASE_DOMAIN=tecuida.es

# ─── Upstash Redis (caché de tenants) ────────────────────────
# URL REST de Upstash Redis (formato: https://xxxx.upstash.io)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io

# Token REST de Upstash Redis
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Modo demo ───────────────────────────────────────────────
# Activar para usar datos simulados sin Supabase real.
# Útil para desarrollo local sin conexión a DB.
# Cambiar a false para producción.
# Valores: true | false
DEMO_MODE=false

# ─── Entorno ─────────────────────────────────────────────────
# Entorno de ejecución: development | production | test
NODE_ENV=development
