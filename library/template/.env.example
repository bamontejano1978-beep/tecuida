# URL base del catálogo Te Cuida (producción o localhost)
TECUIDA_API_URL=https://tecuida.group

# API key para registrar la app en el catálogo
# Obténla del panel de admin de Te Cuida o del .env del monorepo
TECUIDA_API_KEY=tu-api-key-aqui

# URL donde estará desplegada esta app (se rellena tras el primer deploy)
VITE_APP_URL=https://miapp.tecuida.group
